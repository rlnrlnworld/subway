# 공공데이터포털 - 국토교통부 TAGO 지하철정보 API
# https://www.data.go.kr/data/15098554/openapi.do
# 발급 시 Encoding / Decoding 두 키 중 "Decoding 키" 사용 권장
# (URLSearchParams 자동 인코딩 → double-encoding 방지)
TAGO_API_KEY=your_decoding_key_here

# 공공데이터포털 - 서울교통공사 실시간 도착 API (2차 예정)
# https://www.data.go.kr/data/15058052/openapi.do
SEOUL_REALTIME_API_KEY=your_decoding_key_here
